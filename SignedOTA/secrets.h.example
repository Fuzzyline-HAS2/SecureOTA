#ifndef SECRETS_H
#define SECRETS_H

// ============================================================
// secrets.h — HMAC 서명 비밀키 (GitHub 비공개)
//
// [설정 방법]
// 1. 이 파일을 secrets.h 로 복사
//      cp secrets.h.example secrets.h
// 2. 아래 값을 강력한 랜덤 문자열로 변경
//      - WiFi 비밀번호와 다른 값 사용 (바이너리 분석으로 추출 가능)
//      - 권장: 32자 이상 영숫자 + 특수문자 혼합
// 3. scripts/secrets.py 의 HMAC_SECRET 과 반드시 동일하게 설정
//
// [주의]
// - secrets.h 는 .gitignore 에 포함되어 GitHub 에 올라가지 않음
// - 이 파일(secrets.h.example)만 GitHub 에 올라감
// ============================================================

const char *hmac_secret = "CHANGE_THIS_TO_YOUR_SECRET";

#endif // SECRETS_H
